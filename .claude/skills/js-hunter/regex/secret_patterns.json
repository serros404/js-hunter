{
  "aws_access_key": {
    "pattern": "(?:A3T[A-Z0-9]|AKIA|AGPA|AIDA|AROA|AIPA|ANPA|ANVA|ASIA)[A-Z0-9]{16}",
    "risk": "CRITICAL",
    "reason": "AWS Access Key ID"
  },
  "aws_secret_key": {
    "pattern": "(?i)aws.{0,20}(?:secret|key).{0,20}[\"'][0-9a-zA-Z/+=]{40}[\"']",
    "risk": "CRITICAL",
    "reason": "AWS Secret Access Key"
  },
  "generic_api_key": {
    "pattern": "(?i)(?:api[_-]?key|apikey|api[_-]?token|access[_-]?token)[\"']?\\s*[:=]\\s*[\"'][a-zA-Z0-9_\\-]{20,}[\"']",
    "risk": "HIGH",
    "reason": "Generic API key or token assignment"
  },
  "bearer_token_hardcoded": {
    "pattern": "(?i)(?:bearer|authorization)\\s*[:=]\\s*[\"'][a-zA-Z0-9\\._\\-]{20,}[\"']",
    "risk": "HIGH",
    "reason": "Hardcoded Bearer token"
  },
  "jwt_token": {
    "pattern": "eyJ[a-zA-Z0-9_-]{10,}\\.[a-zA-Z0-9_-]{10,}\\.[a-zA-Z0-9_-]{10,}",
    "risk": "HIGH",
    "reason": "JWT token hardcoded in JS"
  },
  "private_key_pem": {
    "pattern": "-----BEGIN (?:RSA |EC |DSA )?PRIVATE KEY-----",
    "risk": "CRITICAL",
    "reason": "Private key PEM block"
  },
  "google_api_key": {
    "pattern": "AIza[0-9A-Za-z\\-_]{35}",
    "risk": "HIGH",
    "reason": "Google API key — check enabled APIs (Maps, Firebase, etc)"
  },
  "stripe_key": {
    "pattern": "(?:sk|pk)_(?:live|test)_[0-9a-zA-Z]{24,}",
    "risk": "CRITICAL",
    "reason": "Stripe API key (live = critical, test = medium)"
  },
  "github_token": {
    "pattern": "(?:ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9]{36}",
    "risk": "HIGH",
    "reason": "GitHub Personal Access Token"
  },
  "slack_token": {
    "pattern": "xox[baprs]-[0-9]{10,12}-[0-9]{10,12}-[a-zA-Z0-9]{24}",
    "risk": "HIGH",
    "reason": "Slack API token"
  },
  "firebase_url": {
    "pattern": "https://[a-z0-9-]+\\.firebaseio\\.com",
    "risk": "MEDIUM",
    "reason": "Firebase database URL — check if public read/write is enabled"
  },
  "internal_endpoint_hardcoded": {
    "pattern": "(?:https?://)?(?:10\\.\\d{1,3}\\.\\d{1,3}\\.\\d{1,3}|172\\.(?:1[6-9]|2[0-9]|3[01])\\.\\d{1,3}\\.\\d{1,3}|192\\.168\\.\\d{1,3}\\.\\d{1,3})(?::\\d+)?/[\\w/]+",
    "risk": "MEDIUM",
    "reason": "Internal/private IP hardcoded in JS — reveals internal architecture"
  },
  "password_in_code": {
    "pattern": "(?i)(?:password|passwd|pwd|secret)\\s*[:=]\\s*[\"'][^\"'\\s]{6,}[\"']",
    "risk": "HIGH",
    "reason": "Hardcoded password or secret value"
  }
}
